<?xml version="1.0"?>
<robot name="my_robot">

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  MATERIALS                                                   -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <material name="gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <material name="dark_gray">
    <color rgba="0.25 0.25 0.25 1.0"/>
  </material>
  <material name="yellow">
    <color rgba="1.0 0.85 0.0 1.0"/>
  </material>
  <material name="midnight_blue">
    <color rgba="0.1 0.1 0.27 1.0"/>
  </material>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  BASE LINK	                                           -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Oberteil.stl"/>
      </geometry>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="3.5 2.0 0.5"/>
      </geometry>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <inertia ixx="0.347" ixy="0.0" ixz="0.0"
               iyy="1.042" iyz="0.0"
               izz="1.250"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  LEFT WHEEL                                                 -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="base_wheel_left">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Rad_links.stl"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.12"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.019" ixy="0.0" ixz="0.0"
               iyy="0.019" iyz="0.0"
               izz="0.034"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  RIGHT WHEEL                                                -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="base_wheel_right">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Rad_rechts.stl"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.12"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.019" ixy="0.0" ixz="0.0"
               iyy="0.019" iyz="0.0"
               izz="0.034"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  SMALL BASE 	                                           -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="small_base">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Unterteil.stl"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="2.0 1.5 0.3"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="3.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.188" ixy="0.0" ixz="0.0"
               iyy="0.250" iyz="0.0"
               izz="0.406"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  FRONT WHEEL                                                -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="small_base_wheel_front">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Rad_vorne.stl"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.12"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0"
               iyy="0.002" iyz="0.0"
               izz="0.002"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  BRUSH LEFT                                                 -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="small_base_brush_left">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Buerste_links.stl"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.15" length="0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.002"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  BRUSH RIGHT                                                -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="small_base_brush_right">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Buerste_rechts.stl"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.15" length="0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.002"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  LIDAR	                                                   -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="lidar">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Lidar.stl"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="yellow"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.04"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA FRONT                                               -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="camera_front">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Kamera_vorne.stl"/>
      </geometry>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <material name="midnight_blue"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.002"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA FRONT FLOOR                                         -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="camera_front_floor">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Kamera_vorne_unten.stl"/>
      </geometry>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <material name="midnight_blue"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.002"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA LEFT                                                -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="camera_left">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Kamera_links.stl"/>
      </geometry>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <material name="midnight_blue"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.002"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA RIGHT                                               -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="camera_right">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Kamera_rechts.stl"/>
      </geometry>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <material name="midnight_blue"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.002"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA BACK                                               -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="camera_back">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Kamera_hinten.stl"/>
      </geometry>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <material name="midnight_blue"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.002"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA BACK FLOOR                                          -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="camera_back_floor">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Kamera_hinten_unten.stl"/>
      </geometry>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <material name="midnight_blue"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.002"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  JOINTS 					                   -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <joint name="wheel_left_to_base" type="continuous">
    <parent link="base_link"/>
    <child link="base_wheel_left"/>
    <origin xyz="-1.59 0.65 0.26" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="wheel_right_to_base" type="continuous">
    <parent link="base_link"/>
    <child link="base_wheel_right"/>
    <origin xyz="-1.59 -0.65 0.26" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="small_base_to_base" type="revolute">
    <parent link="base_link"/>
    <child link="small_base"/>
    <origin xyz="0.15 0 1.3" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.5" upper="0.5" effort="10.0" velocity="1.0"/>
  </joint>

  <joint name="wheel_front_to_small_base" type="continuous">
    <parent link="small_base"/>
    <child link="small_base_wheel_front"/>
    <origin xyz="-0.12 0 -1.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="brush_left_to_small_base" type="continuous">
    <parent link="small_base"/>
    <child link="small_base_brush_left"/>
    <origin xyz="1.05 0.55 -0.925" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="brush_right_to_small_base" type="continuous">
    <parent link="small_base"/>
    <child link="small_base_brush_right"/>
    <origin xyz="1.05 -0.55 -0.925" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="lidar_to_base" type="fixed">
    <parent link="base_link"/>
    <child link="lidar"/>
    <origin xyz="-0.77 0 3.05" rpy="0 0 0"/>
  </joint>

  <joint name="camera_front_to_base" type="fixed">
    <parent link="base_link"/>
    <child link="camera_front"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="camera_front_floor_to_base" type="fixed">
    <parent link="base_link"/>
    <child link="camera_front_floor"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="camera_left_to_base" type="fixed">
    <parent link="base_link"/>
    <child link="camera_left"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="camera_right_to_base" type="fixed">
    <parent link="base_link"/>
    <child link="camera_right"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="camera_back_to_base" type="fixed">
    <parent link="base_link"/>
    <child link="camera_back"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="camera_back_floor_to_base" type="fixed">
    <parent link="base_link"/>
    <child link="camera_back_floor"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  GAZEBO PLUGINS                                             -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <!-- Differential Drive Antrieb -->
  <!-- HINWEIS: Rad-Separation und Radius an dein Modell anpassen! -->
  <!-- wheel_separation = Abstand der beiden Antriebsräder (y-Achse): 2 × 0.65 = 1.3 -->
  <!-- wheel_radius = aus deiner URDF geschätzt: ~0.26                                -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>wheel_left_to_base</left_joint>
      <right_joint>wheel_right_to_base</right_joint>
      <wheel_separation>1.3</wheel_separation>
      <wheel_radius>0.26</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <!-- Topic-Namen werden beim Spawnen per Namespace überschrieben -->
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  JOINT STATE PUBLISHER GAZEBO                               -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>/joint_states</topic>
    </plugin>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  LIDAR GAZEBO                                               -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <gazebo reference="lidar">
    <sensor name="lidar" type="gpu_lidar">
      <topic>/scan</topic>
      <update_rate>10</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
      <always_on>true</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA FRONT GAZEBO                                        -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <gazebo reference="camera_front">
    <sensor name="camera_front" type="rgbd_camera">
      <topic>/camera/front</topic>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
        </image>
        <clip><near>0.1</near><far>10.0</far></clip>
      </camera>
      <always_on>true</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA FRONT FLOOR GAZEBO                                  -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <gazebo reference="camera_front_floor">
    <sensor name="camera_front_floor" type="rgbd_camera">
      <topic>/camera/front/floor</topic>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
        </image>
        <clip><near>0.1</near><far>10.0</far></clip>
      </camera>
      <always_on>true</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA LEFT GAZEBO                                         -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <gazebo reference="camera_left">
    <sensor name="camera_left" type="rgbd_camera">
      <topic>/camera/left</topic>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
        </image>
        <clip><near>0.1</near><far>10.0</far></clip>
      </camera>
      <always_on>true</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA RIGHT GAZEBO                                  -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <gazebo reference="camera_right">
    <sensor name="camera_right" type="rgbd_camera">
      <topic>/camera/right</topic>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
        </image>
        <clip><near>0.1</near><far>10.0</far></clip>
      </camera>
      <always_on>true</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA BACK GAZEBO                                  -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <gazebo reference="camera_back">
    <sensor name="camera_back" type="rgbd_camera">
      <topic>/camera/back</topic>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
        </image>
        <clip><near>0.1</near><far>10.0</far></clip>
      </camera>
      <always_on>true</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA BACK FLOOR GAZEBO                                  -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <gazebo reference="camera_back_floor">
    <sensor name="camera_back_floor" type="rgbd_camera">
      <topic>/camera/back/floor</topic>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
        </image>
        <clip><near>0.1</near><far>10.0</far></clip>
      </camera>
      <always_on>true</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  GAZEBO COLOR                                               -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <gazebo reference="base_link">
    <material>Gazebo/Gray</material>
  </gazebo>
  <gazebo reference="base_wheel_left">
    <material>Gazebo/DarkGray</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="base_wheel_right">
    <material>Gazebo/DarkGray</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="small_base_wheel_front">
    <material>Gazebo/DarkGray</material>
    <mu1>0.1</mu1>
    <mu2>0.1</mu2>
  </gazebo>
  <gazebo reference="small_base">
    <material>Gazebo/Gray</material>
  </gazebo>
  <gazebo reference="base_lidar">
    <material>Gazebo/Black</material>
  </gazebo>

</robot>

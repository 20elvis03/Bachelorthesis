<?xml version="1.0"?>
<robot name="my_robot">
<link name="base_footprint"/>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  MATERIALS                                                  -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <material name="gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <material name="dark_gray">
    <color rgba="0.25 0.25 0.25 1.0"/>
  </material>
  <material name="yellow">
    <color rgba="1.0 0.85 0.0 1.0"/>
  </material>
  <material name="midnight_blue">
    <color rgba="0.1 0.1 0.27 1.0"/>
  </material>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  BASE LINK                                                  -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Oberteil.stl"
              scale="0.4 0.4 0.4"/>
      </geometry>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="1.4 0.8 0.2"/>
      </geometry>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <origin xyz="-0.3 0 0.1" rpy="0 0 0"/>
      <inertia ixx="0.056" ixy="0.0" ixz="0.0"
               iyy="0.167" iyz="0.0"
               izz="0.200"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  LEFT WHEEL                                                 -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="base_wheel_left">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Rad_links.stl"
              scale="0.4 0.4 0.4"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.104" length="0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0"
               iyy="0.003" iyz="0.0"
               izz="0.005"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  RIGHT WHEEL                                                -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="base_wheel_right">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Rad_rechts.stl"
              scale="0.4 0.4 0.4"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.104" length="0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0"
               iyy="0.003" iyz="0.0"
               izz="0.005"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  SMALL BASE 			                           -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="small_base">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Unterteil.stl"
              scale="0.4 0.4 0.4"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.8 0.6 0.12"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <origin xyz="-0.2 0 0" rpy="0 0 0"/>
      <inertia ixx="0.030" ixy="0.0" ixz="0.0"
               iyy="0.040" iyz="0.0"
               izz="0.065"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  FRONT WHEEL                                                -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="small_base_wheel_front">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Rad_vorne.stl"
              scale="0.4 0.4 0.4"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.104" length="0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.003" ixy="0.0" ixz="0.0"
               iyy="0.003" iyz="0.0"
               izz="0.005"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  BRUSH LEFT                                                 -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="small_base_brush_left">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Buerste_links.stl"
              scale="0.4 0.4 0.4"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.06" length="0.02"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0"
               iyy="0.0002" iyz="0.0"
               izz="0.0003"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  BRUSH RIGHT                                                -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="small_base_brush_right">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Buerste_rechts.stl"
              scale="0.4 0.4 0.4"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.06" length="0.02"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0"
               iyy="0.0002" iyz="0.0"
               izz="0.0003"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  LIDAR                                                      -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="lidar">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Lidar.stl"
              scale="0.4 0.4 0.4"/>
      </geometry>
      <origin xyz="0 -0.013 0" rpy="0 0 0"/>
      <material name="yellow"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.02" length="0.016"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA FRONT                                               -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="camera_front">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Kamera_vorne.stl"
              scale="0.4 0.4 0.4"/>
      </geometry>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <material name="midnight_blue"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA FRONT FLOOR                                         -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="camera_front_floor">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Kamera_vorne_unten.stl"
              scale="0.4 0.4 0.4"/>
      </geometry>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <material name="midnight_blue"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA LEFT                                                -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="camera_left">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Kamera_links.stl"
              scale="0.4 0.4 0.4"/>
      </geometry>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <material name="midnight_blue"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA RIGHT                                               -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="camera_right">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Kamera_rechts.stl"
              scale="0.4 0.4 0.4"/>
      </geometry>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <material name="midnight_blue"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA BACK                                                -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="camera_back">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Kamera_hinten.stl"
              scale="0.4 0.4 0.4"/>
      </geometry>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <material name="midnight_blue"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA BACK FLOOR                                          -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <link name="camera_back_floor">
    <visual>
      <geometry>
        <mesh filename="package://my_robot_description/models/Kamera_hinten_unten.stl"
              scale="0.4 0.4 0.4"/>
      </geometry>
      <origin xyz="0 -0.025 0" rpy="0 0 0"/>
      <material name="midnight_blue"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  JOINTS				                           -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <joint name="base_footprint_to_base" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.104" rpy="0 0 0"/>
  </joint>

  <joint name="wheel_left_to_base" type="continuous">
    <parent link="base_link"/>
    <child link="base_wheel_left"/>
    <origin xyz="-0.636 0.241 0.104" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="wheel_right_to_base" type="continuous">
    <parent link="base_link"/>
    <child link="base_wheel_right"/>
    <origin xyz="-0.636 -0.267 0.104" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="small_base_to_base" type="revolute">
    <parent link="base_link"/>
    <child link="small_base"/>
    <origin xyz="0.06 0 0.52" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.5" upper="0.5" effort="10.0" velocity="1.0"/>
  </joint>

  <joint name="wheel_front_to_small_base" type="continuous">
    <parent link="small_base"/>
    <child link="small_base_wheel_front"/>
    <origin xyz="-0.048 0 -0.416" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="brush_left_to_small_base" type="continuous">
    <parent link="small_base"/>
    <child link="small_base_brush_left"/>
    <origin xyz="0.42 0.22 -0.37" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="brush_right_to_small_base" type="continuous">
    <parent link="small_base"/>
    <child link="small_base_brush_right"/>
    <origin xyz="0.42 -0.22 -0.37" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="lidar_to_base" type="fixed">
    <parent link="base_link"/>
    <child link="lidar"/>
    <origin xyz="-0.308 0 1.22" rpy="0 0 0"/>
  </joint>

  <joint name="camera_front_to_base" type="fixed">
    <parent link="base_link"/>
    <child link="camera_front"/>
    <origin xyz="0.346 0.01 0.65" rpy="0 0 0"/>
  </joint>

  <joint name="camera_front_floor_to_base" type="fixed">
    <parent link="base_link"/>
    <child link="camera_front_floor"/>
    <origin xyz="0.35 0.01 0.476" rpy="0 0 0"/>
  </joint>

  <joint name="camera_left_to_base" type="fixed">
    <parent link="base_link"/>
    <child link="camera_left"/>
    <origin xyz="-0.374 0.294 0.56" rpy="0 0 1.5708"/>
  </joint>

  <joint name="camera_right_to_base" type="fixed">
    <parent link="base_link"/>
    <child link="camera_right"/>
    <origin xyz="-0.33 -0.32 0.56" rpy="0 0 -1.5708"/>
  </joint>

  <joint name="camera_back_to_base" type="fixed">
    <parent link="base_link"/>
    <child link="camera_back"/>
    <origin xyz="-0.765 -0.025 0.56" rpy="0 0 3.1416"/>
  </joint>

  <joint name="camera_back_floor_to_base" type="fixed">
    <parent link="base_link"/>
    <child link="camera_back_floor"/>
    <origin xyz="-0.77 -0.025 0.4615" rpy="0 0 3.1416"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  GAZEBO PLUGINS                                             -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <gazebo>
    <plugin filename="libgz-sim9-diff-drive-system.so"
            name="gz::sim::systems::DiffDrive">
      <left_joint>wheel_left_to_base</left_joint>
      <right_joint>wheel_right_to_base</right_joint>
      <wheel_separation>0.508</wheel_separation>
      <wheel_radius>0.104</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="libgz-sim9-joint-position-controller-system.so"
        name="gz::sim::systems::JointPositionController">
      <joint_name>small_base_to_base</joint_name>
      <topic>/steering</topic>
      <p_gain>10.0</p_gain>
      <i_gain>0.0</i_gain>
      <d_gain>0.5</d_gain>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="libgz-sim9-joint-state-publisher-system.so"
        name="gz::sim::systems::JointStatePublisher">
      <topic>/joint_states</topic>
    </plugin>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  LIDAR GAZEBO                                               -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <gazebo reference="lidar">
    <sensor name="lidar" type="gpu_lidar">
      <pose>0 0 0.78 0 0 0</pose>
      <topic>/scan</topic>
      <frame_id>lidar</frame_id>
      <update_rate>10</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>1200</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>64</samples>
            <resolution>1</resolution>
            <min_angle>-1.0</min_angle>
            <max_angle>0.15</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.15</min>
          <max>5.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
      <ignoreEntities>
        <entity>my_robot::base_link</entity>
        <entity>my_robot::base_footprint</entity>
        <entity>my_robot::base_wheel_left</entity>
        <entity>my_robot::base_wheel_right</entity>
        <entity>my_robot::small_base</entity>
        <entity>my_robot::small_base_wheel_front</entity>
        <entity>my_robot::small_base_brush_left</entity>
        <entity>my_robot::small_base_brush_right</entity>
        <entity>my_robot::lidar</entity>
        <entity>my_robot::camera_front</entity>
        <entity>my_robot::camera_front_floor</entity>
        <entity>my_robot::camera_left</entity>
        <entity>my_robot::camera_right</entity>
        <entity>my_robot::camera_back</entity>
        <entity>my_robot::camera_back_floor</entity>
      </ignoreEntities>
      <always_on>true</always_on>
      <visualize>false</visualize>
    </sensor>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA FRONT GAZEBO                                        -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <gazebo reference="camera_front">
    <sensor name="camera_front" type="rgbd_camera">
      <topic>/camera/front</topic>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
        </image>
        <clip><near>0.3</near><far>60.0</far></clip>
      </camera>
      <always_on>true</always_on>
      <visualize>false</visualize>
    </sensor>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA FRONT FLOOR GAZEBO                                  -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <gazebo reference="camera_front_floor">
    <sensor name="camera_front_floor" type="rgbd_camera">
      <topic>/camera/front/floor</topic>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
        </image>
        <clip><near>0.3</near><far>60.0</far></clip>
      </camera>
      <always_on>true</always_on>
      <visualize>false</visualize>
    </sensor>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA LEFT GAZEBO                                         -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <gazebo reference="camera_left">
    <sensor name="camera_left" type="rgbd_camera">
      <topic>/camera/left</topic>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
        </image>
        <clip><near>0.3</near><far>60.0</far></clip>
      </camera>
      <always_on>true</always_on>
      <visualize>false</visualize>
    </sensor>
  </gazebo>


  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA RIGHT GAZEBO                                        -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <gazebo reference="camera_right">
    <sensor name="camera_right" type="rgbd_camera">
      <topic>/camera/right</topic>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
        </image>
        <clip><near>0.3</near><far>60.0</far></clip>
      </camera>
      <always_on>true</always_on>
      <visualize>false</visualize>
    </sensor>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA BACK GAZEBO                                         -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <gazebo reference="camera_back">
    <sensor name="camera_back" type="rgbd_camera">
      <topic>/camera/back</topic>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
        </image>
        <clip><near>0.3</near><far>60.0</far></clip>
      </camera>
      <always_on>true</always_on>
      <visualize>false</visualize>
    </sensor>
  </gazebo>


  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CAMERA BACK FLOOR GAZEBO                                   -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <gazebo reference="camera_back_floor">
    <sensor name="camera_back_floor" type="rgbd_camera">
      <topic>/camera/back/floor</topic>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
        </image>
        <clip><near>0.3</near><far>60.0</far></clip>
      </camera>
      <always_on>true</always_on>
      <visualize>false</visualize>
    </sensor>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  GAZEBO REFERENCES                                          -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <gazebo reference="base_link">
    <material>Gazebo/Gray</material>
  </gazebo>

  <gazebo reference="base_wheel_left">
    <material>Gazebo/DarkGray</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
  </gazebo>

  <gazebo reference="base_wheel_right">
    <material>Gazebo/DarkGray</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
  </gazebo>

  <gazebo reference="small_base_wheel_front">
    <material>Gazebo/DarkGray</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
  </gazebo>

</robot>

<?xml version="1.0" ?>
<sdf version="1.10">
  <world name="airport_terminal_world">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  SYSTEM PLUGINS                                             -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-contact-system" name="gz::sim::systems::Contact"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  PHYSICS                                                    -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <physics name="default_physics" type="ignored">
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>100.0</real_time_update_rate>
      <max_step_size>0.01</max_step_size>
    </physics>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  SCENE & LIGHTING                                           -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <scene>
      <ambient>0.5 0.5 0.5 1.0</ambient>
      <background>0.53 0.81 0.98 1.0</background>
      <shadows>true</shadows>
    </scene>

    <light name="light_main" type="directional">
      <pose>0 0 10.0 0 0 0</pose>
      <cast_shadows>false</cast_shadows>
      <diffuse>0.6 0.6 0.6 1.0</diffuse>
      <specular>0.1 0.1 0.1 1.0</specular>
      <direction>0.1 0.1 -1.0</direction>
      <attenuation>
        <range>1000.0</range>
        <constant>1.0</constant>
        <linear>0</linear>
        <quadratic>0</quadratic>
      </attenuation>
    </light>

